{
  "name": "sitedeck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "description": "여러 GA4 사이트의 핵심 지표를 한 화면에 요약하는 로컬 대시보드",
  "license": "MIT",
  "author": "Si Hyeong Lee",
  "keywords": [
    "google-analytics",
    "ga4",
    "analytics",
    "dashboard",
    "oauth",
    "typescript",
    "self-hosted"
  ],
  "engines": {
    "node": ">=20"
