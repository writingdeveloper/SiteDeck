{
  "name": "sitedeck",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "description": "여러 GA4 사이트의 핵심 지표를 한 화면에 요약하는 로컬 대시보드",
  "license": "MIT",
  "author": "Si Hyeong Lee",
  "keywords": [
    "google-analytics",
    "ga4",
    "analytics",
    "dashboard",
    "oauth",
    "typescript",
    "self-hosted"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/writingdeveloper/SiteDeck.git"
  },
  "bugs": {
    "url": "https://github.com/writingdeveloper/SiteDeck/issues"
  },
  "homepage": "https://github.com/writingdeveloper/SiteDeck#readme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "electron": "electron .",
    "build:server": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node20 --packages=external --outfile=dist/server.mjs",
    "pack": "npm run build:server && electron-builder --dir",
    "dist": "npm run build:server && electron-builder",
    "release": "npm run build:server && electron-builder --publish always",
    "icon": "node scripts/make-icon.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google-analytics/admin": "^9.1.0",
    "@google-analytics/data": "^6.1.0",
    "electron-updater": "^6.8.9",
    "google-auth-library": "^10.7.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "png-to-ico": "^3.0.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.sitedeck.app",
    "productName": "SiteDeck",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "!**/*.test.ts",
      "!credentials.json*",
      "!.github/**",
      "!docs/**",
      "!release/**",
      "!src/**",
      "!scripts/**",
      "!tsconfig.json",
      "!vitest.config.ts",
      "!README.*.md",
      "!.gitignore",
      "!SECURITY.md",
      "!CONTRIBUTING.md"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "writingdeveloper",
        "repo": "SiteDeck",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
